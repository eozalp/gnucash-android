<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121214">

    <!-- Console Output Log List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/console_output"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:scrollbars="vertical" />

    <!-- Suggestion Bar -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/suggestion_recycler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#1A1A22"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2E2E3E" />

    <!-- Command Input Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:gravity="center_vertical"
        android:background="#1E1E24">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="> "
            android:textColor="@color/abs__holo_blue_light"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <EditText
            android:id="@+id/command_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Type command (e.g. help)"
            android:textColorHint="#6E6E7E"
            android:textColor="@android:color/white"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:imeOptions="actionSend"
            android:background="@android:color/transparent"
            android:minHeight="48dp"
            android:paddingHorizontal="4dp"/>

        <Button
            android:id="@+id/btn_run"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Run"
            android:textColor="@android:color/white"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

</LinearLayout>
